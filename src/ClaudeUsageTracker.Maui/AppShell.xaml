<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="ClaudeUsageTracker.Maui.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:ClaudeUsageTracker.Maui.Views"
    Title="Claude Usage Tracker">

    <ShellContent
        Title="Providers"
        ContentTemplate="{DataTemplate views:ProvidersDashboardPage}"
        Route="providers" />

    <ShellContent
        Title="Dashboard"
        ContentTemplate="{DataTemplate views:DashboardPage}"
        Route="dashboard" />

    <ShellContent
        Title="Setup"
        ContentTemplate="{DataTemplate views:SetupPage}"
        Route="setup" />

</Shell>
