<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ClaudeUsageTracker.Maui.ViewModels"
             xmlns:controls="clr-namespace:ClaudeUsageTracker.Maui.Controls"
             x:Class="ClaudeUsageTracker.Maui.Views.ProvidersDashboardPage"
             Title="Providers">

    <Grid RowDefinitions="Auto,Auto,Auto,*" Padding="20" RowSpacing="16">

        <!-- Hidden WebView for silent Claude quota fetch — lives in page layout context, not AppShell -->
        <WebView x:Name="ClaudeSilentWebView" Grid.Row="0" Grid.RowSpan="4"
                 IsVisible="False"
                 Source="https://claude.ai/settings/usage" />

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
            <Label Grid.Column="0" Text="Plan Usage" FontSize="22" FontAttributes="Bold" VerticalOptions="Center" />
            <Grid Grid.Column="1">
                <Button Text="Refresh All" FontSize="13"
                        Command="{Binding RefreshAllCommand}"
                        IsVisible="{Binding ShowRefreshAllSpinner, Converter={StaticResource InvertedBoolConverter}}"
                        BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" />
                <ActivityIndicator IsRunning="{Binding ShowRefreshAllSpinner}"
                                   IsVisible="{Binding ShowRefreshAllSpinner}"
                                   WidthRequest="22" HeightRequest="22"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
            </Grid>
        </Grid>

        <!-- Update Banner — Row 1, shown when update is available or actively installing -->
        <Border Grid.Row="1"
                IsVisible="{Binding UpdateService.ShowUpdateBanner}"
                BackgroundColor="{AppThemeBinding Light=#1B4332, Dark=#1A2E22}"
                StrokeThickness="1"
                Stroke="#2D6A4F"
                StrokeShape="RoundRectangle 8"
                Padding="16,10">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="4">
                    <Label Text="{Binding UpdateService.BannerTitle}"
                           FontSize="13" FontAttributes="Bold" TextColor="#81C995" />
                    <ProgressBar IsVisible="{Binding UpdateService.IsUpdating}"
                                 Progress="{Binding UpdateService.UpdateProgressFraction}"
                                 ProgressColor="#4CAF50" HeightRequest="4" />
                    <Label Text="{Binding UpdateService.ReleaseNotes}"
                           FontSize="11"
                           TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}"
                           IsVisible="{Binding UpdateService.IsUpdating, Converter={StaticResource InvertedBoolConverter}}"
                           MaxLines="2" LineBreakMode="TailTruncation" />
                </VerticalStackLayout>
                <Button Grid.Column="1"
                        Text="{Binding UpdateService.UpdateButtonText}"
                        Command="{Binding UpdateService.ApplyUpdateCommand}"
                        IsEnabled="{Binding UpdateService.IsUpdating, Converter={StaticResource InvertedBoolConverter}}"
                        BackgroundColor="#4CAF50" TextColor="White"
                        CornerRadius="6" FontSize="12" HeightRequest="36"
                        VerticalOptions="Center" />
            </Grid>
        </Border>

        <!-- Auto-refresh controls -->
        <Grid Grid.Row="2" ColumnDefinitions="Auto,Auto,Auto,*" ColumnSpacing="8" VerticalOptions="Center">
            <Label Grid.Column="0" Text="Auto refresh every" FontSize="13" VerticalOptions="Center"
                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
            <Entry Grid.Column="1" Text="{Binding AutoRefreshMinutes}"
                   Keyboard="Numeric" WidthRequest="50" FontSize="13"
                   HorizontalTextAlignment="Center" VerticalOptions="Center"
                   IsEnabled="{Binding IsAutoRefreshRunning, Converter={StaticResource InvertedBoolConverter}}" />
            <Label Grid.Column="2" Text="min" FontSize="13" VerticalOptions="Center"
                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
            <Button Grid.Column="3" Text="{Binding AutoRefreshToggleText}"
                    Command="{Binding ToggleAutoRefreshCommand}"
                    FontSize="13" HorizontalOptions="Start" />
        </Grid>

        <!-- Provider cards list -->
        <ScrollView Grid.Row="3">
            <VerticalStackLayout Spacing="12">

                <!-- Empty state -->
                <VerticalStackLayout IsVisible="{Binding Providers.Count, Converter={StaticResource CountToBoolConverter}}"
                                    VerticalOptions="Center" HorizontalOptions="Center" Padding="0,40">
                    <Label Text="No providers connected" FontSize="16" HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" />
                    <Label Text="Add API keys in Settings to see usage here" FontSize="13" HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}" />
                </VerticalStackLayout>

                <!-- Provider cards -->
                <CollectionView ItemsSource="{Binding Providers}"
                                IsVisible="{Binding Providers.Count, Converter={StaticResource CountToBoolConverter}, ConverterParameter=inverse}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame CornerRadius="10" Padding="20"
                                   BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}">
                                <VerticalStackLayout Spacing="12">

                                    <!-- Card header -->
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Grid.Column="0" Text="{Binding ProviderName}" FontSize="18" FontAttributes="Bold" />
                                        <Grid Grid.Column="1" WidthRequest="36" HeightRequest="36">
                                            <Button Text="↻" FontSize="16"
                                                    Command="{Binding RefreshThisCommand}"
                                                    IsVisible="{Binding IsRefreshing, Converter={StaticResource InvertedBoolConverter}}"
                                                    BackgroundColor="Transparent"
                                                    TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" />
                                            <ActivityIndicator IsRunning="{Binding IsRefreshing}"
                                                               IsVisible="{Binding IsRefreshing}"
                                                               WidthRequest="20" HeightRequest="20"
                                                               HorizontalOptions="Center" VerticalOptions="Center" />
                                        </Grid>
                                    </Grid>

                                    <!-- Interval row -->
                                    <VerticalStackLayout Spacing="4">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <Label Grid.Column="0" Text="Session" FontSize="12"
                                                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
                                            <Label Grid.Column="1" FontSize="12" VerticalOptions="Center">
                                                <Label.FormattedText>
                                                    <FormattedString>
                                                        <Span Text="{Binding IntervalUsed, StringFormat='{0:N0}'}" FontAttributes="Bold" />
                                                        <Span Text=" / " />
                                                        <Span Text="{Binding IntervalTotal, StringFormat='{0:N0}'}" />
                                                        <Span Text=" units" />
                                                    </FormattedString>
                                                </Label.FormattedText>
                                            </Label>
                                        </Grid>
                                        <controls:ColorProgressBar x:Name="IntervalProgressBar"
                                                                         ProgressPercent="{Binding IntervalUtilization}"
                                                                         Margin="0,2,0,0" />
                                        <Grid ColumnDefinitions="*,Auto">
                                            <Label Grid.Column="0" FontSize="12"
                                                   TextColor="{Binding Source={x:Reference IntervalProgressBar}, Path=DisplayColor}">
                                                <Label.FormattedText>
                                                    <FormattedString>
                                                        <Span Text="{Binding IntervalUtilization, StringFormat='{0}%'}"/>
                                                        <Span Text=" used" />
                                                    </FormattedString>
                                                </Label.FormattedText>
                                            </Label>
                                            <Label Grid.Column="1" Text="{Binding IntervalResetsAt}" FontSize="11"
                                                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
                                        </Grid>
                                    </VerticalStackLayout>

                                    <!-- Weekly row -->
                                    <VerticalStackLayout Spacing="4">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <Label Grid.Column="0" Text="Weekly" FontSize="12"
                                                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
                                            <Label Grid.Column="1" FontSize="12" VerticalOptions="Center">
                                                <Label.FormattedText>
                                                    <FormattedString>
                                                        <Span Text="{Binding WeeklyUsed, StringFormat='{0:N0}'}" FontAttributes="Bold" />
                                                        <Span Text=" / " />
                                                        <Span Text="{Binding WeeklyTotal, StringFormat='{0:N0}'}" />
                                                        <Span Text=" units" />
                                                    </FormattedString>
                                                </Label.FormattedText>
                                            </Label>
                                        </Grid>
                                        <controls:ColorProgressBar x:Name="WeeklyProgressBar"
                                                                         ProgressPercent="{Binding WeeklyUtilization}"
                                                                         Margin="0,2,0,0" />
                                        <Grid ColumnDefinitions="*,Auto">
                                            <Label Grid.Column="0" FontSize="12"
                                                   TextColor="{Binding Source={x:Reference WeeklyProgressBar}, Path=DisplayColor}">
                                                <Label.FormattedText>
                                                    <FormattedString>
                                                        <Span Text="{Binding WeeklyUtilization, StringFormat='{0}%'}" />
                                                        <Span Text=" used" />
                                                    </FormattedString>
                                                </Label.FormattedText>
                                            </Label>
                                            <Label Grid.Column="1" Text="{Binding WeeklyResetsAt}" FontSize="11"
                                                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
                                        </Grid>
                                    </VerticalStackLayout>

                                    <!-- Error -->
                                    <Label Text="{Binding ErrorMessage}" TextColor="Red" FontSize="11"
                                           IsVisible="{Binding HasError}" />

                                    <!-- Last updated -->
                                    <Label Text="{Binding LastUpdated, StringFormat='Updated {0}'}" FontSize="10"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" />

                                </VerticalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
